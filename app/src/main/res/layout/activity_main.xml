<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FDE9C0"
    tools:context=".MainActivity">



    <!-- Toolbar -->

    <!-- Search Bar -->

    <LinearLayout
        android:layout_width="378dp"
        android:layout_height="185dp"
        android:background="@drawable/makanan"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <!-- Profile Icon -->



        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/search_background" />

        <TextView
            android:layout_width="270dp"
            android:layout_height="112dp"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="TEMUKAN RESEP MAKANAN\nDAN KULINER DISINI 🍲"
            android:textColor="#FAF6EC"
            android:textSize="26sp" />
        <!-- Profile Icon Positioned on Top-Right Corner of Background Image -->
        <ImageView
            android:id="@+id/profileIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@drawable/name"
            app:tint="#FAF6EC"
            android:contentDescription="Profile Icon" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="366dp"
        android:layout_height="39dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/search_bar"
            android:layout_width="0dp"
            android:layout_height="39dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Search"
            android:minHeight="48dp"
            android:padding="8dp"
            android:textColor="#333333"
            android:textSize="18sp"
            tools:ignore="TouchTargetSizeCheck" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="4dp"
            android:src="@drawable/burger"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Filter Tags -->

    <!-- Result Count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/spicyButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#FFA726"
            android:text="Spicy"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/healthyButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#66BB6A"
            android:text="Healthy"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/veganButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#8D6E63"
            android:text="Vegan"
            android:textColor="#FFFFFF" />

        <!-- New Button -->
    </LinearLayout>

    <TextView
        android:layout_width="155dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="DAFTAR \nMAKANAN"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Grid of Results -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Item 1 -->
                <LinearLayout
                    android:id="@+id/foodItemBurger"
                    android:layout_width="0dp"
                    android:layout_height="182dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage1"
                        android:layout_width="150dp"
                        android:layout_height="105dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/burger1" />

                    <TextView
                        android:id="@+id/foodName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Burger"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Delicious beef burger"
                        android:textColor="#777777"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Item 2 -->
                <LinearLayout
                    android:id="@+id/foodItemRendang"
                    android:layout_width="0dp"
                    android:layout_height="182dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage2"
                        android:layout_width="150dp"
                        android:layout_height="105dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/rendang" />

                    <TextView
                        android:id="@+id/foodName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Rendang"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Khas padang "
                        android:textColor="#777777"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Item 3 -->
                <LinearLayout
                    android:id="@+id/foodItemSusuGandum"
                    android:layout_width="0dp"
                    android:layout_height="182dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage3"
                        android:layout_width="143dp"
                        android:layout_height="112dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/susugandum" />

                    <TextView
                        android:id="@+id/foodName3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Susu gandum"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Minuman sehat"
                        android:textColor="#777777"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Item 4 (Cheeseburger) -->
                <LinearLayout
                    android:id="@+id/foodItemRotiGandum"
                    android:layout_width="0dp"
                    android:layout_height="182dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage4"
                        android:layout_width="146dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bread" />

                    <TextView
                        android:id="@+id/foodName4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Roti Gandum"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="kenikmatan khas eropa"
                        android:textColor="#777777"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>

            <!-- Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Item 5 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="185dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage8"
                        android:layout_width="150dp"
                        android:layout_height="105dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/burger" />

                    <TextView
                        android:id="@+id/foodName8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Pasta"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Italian classic"
                        android:textColor="#777777"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Item 6 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="185dp"
                    android:layout_margin="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/item_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/foodImage9"
                        android:layout_width="150dp"
                        android:layout_height="105dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/burger" />

                    <TextView
                        android:id="@+id/foodName9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Pasta"
                        android:textColor="#333333"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/foodDescription9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Italian classic"
                        android:textColor="#777777"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Add more items in pairs as needed -->

        </LinearLayout>
    </ScrollView>
</LinearLayout>
